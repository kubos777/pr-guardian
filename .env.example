# ========================
# GitHub
# ========================
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_API_URL=https://api.github.com

# ========================
# LLM (Claude)
# ========================
LLM_API_KEY=your_anthropic_api_key
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.2

# ========================
# Queue / Broker (Celery + Redis)
# ========================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Context Cache: ephemeral GitHub API/config data, stored in Redis with a TTL.
# Conceptually separate from the durable Job Store below.
CONTEXT_CACHE_TTL_SECONDS=300

# ========================
# Job Store (durable execution state)
# ========================
# SQLite file holding jobs, job_events, findings and history_examples.
# Never committed — see .gitignore (data/*.db, data/*.db-shm, data/*.db-wal).
PR_GUARDIAN_DB_PATH=data/pr_guardian.db

# ========================
# Retry policy
# ========================
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_BASE_SECONDS=2
RETRY_BACKOFF_MAX_SECONDS=30

# ========================
# Servers
# ========================
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
MCP_SERVER_PORT=8080
DASHBOARD_URL=http://localhost:3000
